<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="750.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.lj1_bd_2sem.controller.PagamentoAtendimentoController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <VBox spacing="5.0">
            <children>
                <Label text="Atendimentos Em Andamento &amp; Pagamento">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Label text="Selecione um serviço em execução na lista abaixo para processar a cobrança." textFill="#7f8c8d" />
            </children>
        </VBox>

        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
            <children>
                <Label text="Fila de Atendimento Atual:">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <TableView fx:id="tabelaEmAndamento" onMouseClicked="#carregarDetalhesAgendamento" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="colHora" prefWidth="100.0" text="Horário" />
                        <TableColumn fx:id="colCliente" prefWidth="180.0" text="Cliente (ID)" />
                        <TableColumn fx:id="colProfissional" prefWidth="180.0" text="Profissional" />
                        <TableColumn fx:id="colServico" prefWidth="180.0" text="Serviço" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>

        <VBox spacing="15.0" style="-fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0; -fx-padding: 15 0 0 0;">
            <children>
                <Label text="Detalhes da Cobrança" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="15.0" />
                    </font>
                </Label>

                <GridPane hgap="15.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" minWidth="130.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints hgrow="NEVER" minWidth="130.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="30.0" />
                        <RowConstraints minHeight="30.0" />
                    </rowConstraints>
                    <children>
                        <Label text="ID do Agendamento:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtIdAgendamento" editable="false" style="-fx-background-color: #eee;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Cliente selecionado:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <TextField fx:id="txtIdCliente" editable="false" style="-fx-background-color: #eee;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                        <Label text="Saldo Atual do Cliente:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="txtBalancaCliente" editable="false" style="-fx-background-color: #e8f4f8; -fx-text-fill: #2980b9; -fx-font-weight: bold;" text="R$ 0,00" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Forma de Pagamento:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <ComboBox fx:id="comboFormaPagamento" prefWidth="200.0" promptText="Selecione..." GridPane.columnIndex="3" GridPane.rowIndex="1" />
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="25.0">
                    <children>
                        <VBox alignment="CENTER_RIGHT">
                            <children>
                                <Label text="VALOR DO SERVIÇO:" textFill="#7f8c8d">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblValorServico" text="R$ 0,00" textFill="#27ae60">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER_RIGHT" spacing="5.0">
                            <children>
                                <Button fx:id="btnFinalizarPagamento" mnemonicParsing="false" onAction="#processarPagamento" prefHeight="50.0" prefWidth="220.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Finalizar e Debitar">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Button>
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets top="10.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>