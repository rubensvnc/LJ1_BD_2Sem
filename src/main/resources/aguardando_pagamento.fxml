<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="30.0" prefWidth="600.0" prefHeight="400.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.lj1_bd_2sem.controller.AguardandoPagamentoController">
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
    <children>
        <Label fx:id="lblMensagem" text="Aguardando confirmação do pagamento" textFill="#2c3e50">
            <font><Font size="28.0" name="System Bold" /></font>
        </Label>
        <Button fx:id="btnLimparCabelos" text="LIMPAR CABELOS DO CHÃO" visible="false" managed="false" onAction="#limparCabelosChao" style="-fx-background-color: #e67e22; -fx-text-fill: white;">
            <font><Font size="16.0" name="System Bold" /></font>
        </Button>
    </children>
</VBox>