<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="1000.0" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.lj1_bd_2sem.controller.VendasProdutosController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="Frente de Caixa (PDV)">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>

                <VBox spacing="10.0" HBox.hgrow="ALWAYS" prefWidth="480.0">
                    <children>
                        <Label text="Itens disponíveis:">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>

                        <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                            <content>
                                <TableView fx:id="tabelaCarrinho" minHeight="300.0">
                                    <columns>
                                        <TableColumn fx:id="colProduto" prefWidth="200.0" text="Produto" />
                                        <TableColumn fx:id="colQtd" prefWidth="60.0" text="Qtd" />
                                        <TableColumn fx:id="colPrecoUnitario" prefWidth="100.0" text="Preço Unit." />
                                        <TableColumn fx:id="colTotalItem" prefWidth="100.0" text="Total" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <VBox spacing="10.0" HBox.hgrow="ALWAYS" prefWidth="480.0">
                    <children>
                        <Label text="Carrinho:">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>

                        <HBox alignment="BOTTOM_LEFT" spacing="10.0">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Cód. Barras / ID do Produto:" />
                                        <TextField fx:id="txtCodigoProduto" prefWidth="150.0" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Quantidade:" />
                                        <TextField fx:id="txtQuantidade" prefWidth="80.0" text="1" />
                                    </children>
                                </VBox>
                                <Button fx:id="btnAdicionar" mnemonicParsing="false" onAction="#adicionarItem" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Adicionar Item" />
                            </children>
                        </HBox>

                        <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                            <content>
                                <TableView fx:id="tabelaCarrinho1" minHeight="300.0">
                                    <columns>
                                        <TableColumn fx:id="colProduto1" prefWidth="200.0" text="Produto" />
                                        <TableColumn fx:id="colQtd1" prefWidth="60.0" text="Qtd" />
                                        <TableColumn fx:id="colPrecoUnitario1" prefWidth="100.0" text="Preço Unit." />
                                        <TableColumn fx:id="colTotalItem1" prefWidth="100.0" text="Total" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

            </children>
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="20.0">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Forma de Pagamento:" />
                        <ComboBox fx:id="comboPagamento" prefWidth="150.0" />
                    </children>
                </VBox>
                <VBox alignment="CENTER_RIGHT">
                    <children>
                        <Label text="TOTAL DA VENDA:" textFill="#7f8c8d">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblTotalVenda" text="R$ 0,00" textFill="#c0392b">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                <Button fx:id="btnFinalizarVenda" mnemonicParsing="false" onAction="#finalizarVenda" prefHeight="50.0" prefWidth="180.0" style="-fx-background-color: #2980b9; -fx-text-fill: white;" text="Finalizar Venda">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>