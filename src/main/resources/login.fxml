<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.layout.HBox?>
<VBox alignment="CENTER" spacing="15.0" prefWidth="400.0" prefHeight="300.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.lj1_bd_2sem.controller.LoginController">
    <padding>
        <Insets top="20.0" right="40.0" bottom="20.0" left="40.0"/>
    </padding>
    <children>
        <Label text="MultiGestão Hub">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Label text="Por favor, faça o login para continuar" textFill="#737373" />

        <VBox spacing="5.0">
            <children>
                <Label text="Usuário:" />
                <TextField fx:id="txtUsuario" promptText="Digite seu login" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Senha:" />
                <PasswordField fx:id="txtSenha" promptText="Digite sua senha" />
            </children>
        </VBox>

        <Button fx:id="btnEntrar" mnemonicParsing="false" onAction="#handleLogin" prefWidth="150.0" text="Entrar" style="-fx-background-color: #2196F3; -fx-text-fill: white;">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>
        <Label fx:id="lblErro" textFill="RED" />
        <HBox alignment="CENTER" spacing="5.0">
            <children>
                <Label text="Não possui uma conta?" textFill="#7f8c8d" />
                <Hyperlink fx:id="linkLogin" onAction="#irParaTelaCadastro" text="Faça cadastro aqui" textFill="#2980b9">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Hyperlink>
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>